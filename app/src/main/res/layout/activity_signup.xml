<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6B672"
    tools:context=".Signup">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" ⚝SignUp ⚝"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:fontFamily="cursive"
        android:background="@drawable/shape"
        android:backgroundTint="#C3B047"
        android:padding="12dp"
        android:textColor="#1E3519"/>

<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

<!--            Below is the edit text for username-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 🪪 Enter Your Username "
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:background="#793"
                android:padding="10dp"/>

            <!--            Below is the edit text for email-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 📧 Enter Your Email Address "
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/email"
                android:inputType="textEmailAddress"
                android:layout_margin="8dp"
                android:background="#793"
                android:padding="10dp"/>

            <!--            Below is the edit text for password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 🔑 Enter Your Password "
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:background="#793"
                android:padding="10dp"/>

            <!--            Below is the edit text for phone number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 📞 Enter Your Phone Number"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:background="#793"
                android:padding="10dp"/>

<!--            Below is the signup button-->


            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  ➕ Sign Up"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="25dp"
                android:textColor="#123"
                android:backgroundTint="#363"
                android:id="@+id/signupBtn"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already Have An Account? Sign In"
                android:textAlignment="center"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="#0013e9"
                android:id="@+id/signintxt"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
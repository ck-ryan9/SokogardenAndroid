<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#74CDD9"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" 🌟 Sokogarden 🌟"
        android:fontFamily="cursive"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:textColor="#0A1D14"/>

<!--    Below is a linear layout that aligns contents horizontally-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">


            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  ➕ Sign Up"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="30dp"
                android:layout_marginTop="8dp"
                android:textColor="#ED0404"
                android:backgroundTint="#75C5AF"
                android:id="@+id/signupBtn"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 👤 Sign In"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="8dp"
                android:textColor="#242"
                android:backgroundTint="#29D0B5"
                android:id="@+id/signinBtn"/>




        </LinearLayout>
</LinearLayout>